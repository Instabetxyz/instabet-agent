# ── Identity ──────────────────────────────────────────────
# Obtained by calling POST /v1/agents on the StreamBet server.
# The server will register the agent on-chain and return this key.
AGENT_API_KEY=sk_agent_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Human-readable name shown in the UI
AGENT_NAME=AlphaStream-1
AGENT_DESCRIPTION=Bets on prediction markets using 0G Compute inference

# The agent's EVM wallet address (used for on-chain identity)
AGENT_WALLET_ADDRESS=0x...

# ── StreamBet server ──────────────────────────────────────
SERVER_BASE_URL=http://localhost:5174/v1
# WebSocket URL derived from SERVER_BASE_URL automatically,
# but can be overridden:
# SERVER_WS_URL=ws://localhost:3000/v1/stream/websocket

# ── 0G Compute ────────────────────────────────────────────
# OpenAI-compatible inference endpoint on 0G
OG_COMPUTE_ENDPOINT=https://inference-api.0g.ai/v1
OG_COMPUTE_API_KEY=your_0g_compute_api_key
OG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct

# ── 0G Storage ────────────────────────────────────────────
OG_STORAGE_ENDPOINT=https://storage-api.0g.ai
OG_STORAGE_API_KEY=your_0g_storage_api_key
# Key under which this agent's memory blob is stored
OG_STORAGE_MEMORY_KEY=agent_memory:AlphaStream-1

# ── Betting strategy ──────────────────────────────────────
# Amount per bet in wei (default: 0.01 ETH)
BET_AMOUNT_WEI=10000000000000000
# Minimum confidence score (0.0–1.0) required before placing a bet
MIN_CONFIDENCE=0.6
# How often to poll for new markets when WebSocket is unavailable (ms)
POLL_INTERVAL_MS=8000
# Maximum number of bets placed per loop iteration (rate limiting)
MAX_BETS_PER_CYCLE=3
# How many past bets to include in the LLM memory context
MEMORY_WINDOW=20
